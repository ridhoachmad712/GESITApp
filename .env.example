# =============================================================
# SIARSIP Manajemen FEB UNM
# Production (Hostinger): APP_ENV=production, APP_DEBUG=false,
# APP_URL=https://domain-anda — lalu jalankan php artisan config:cache
# =============================================================
APP_NAME="SIARSIP Manajemen"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=siarsip
DB_USERNAME=root
DB_PASSWORD=
# Folder berisi mysqldump bila tidak ada di PATH (lokal XAMPP: C:/xampp/mysql/bin).
# Di Hostinger biasanya kosongkan saja.
DB_DUMP_BINARY_PATH=

# ---- Backup (spatie/laravel-backup) ----
# Tujuan backup; 'local' = storage/app/private. Di production WAJIB arahkan
# ke disk eksternal (S3/FTP) yang dikonfigurasi di config/filesystems.php.
BACKUP_DISK=local
# true di server Linux (butuh binary gzip); false di Windows lokal.
BACKUP_COMPRESS_DB=false
# Email penerima notifikasi kegagalan backup.
BACKUP_NOTIFICATION_EMAIL=admin@manajemen-feb.unm.ac.id

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: ganti ke SMTP Hostinger (MAIL_MAILER=smtp, host smtp.hostinger.com,
# port 465, MAIL_SCHEME=smtps) agar reset password & notifikasi backup terkirim.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="arsip@manajemen-feb.unm.ac.id"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
